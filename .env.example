# 数据库路径（相对于项目根目录）
DATABASE_PATH=./data/weekly.db

# API 写入鉴权 Key（OpenClaw 通过 HTTP API 写入时使用）
API_KEY=your-secret-api-key

# Anthropic API Key（process-data.js AI分类摘要用）
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Token（提升 API 速率限制，可选）
GITHUB_TOKEN=ghp_...

# SkillsMP API（可选）
SKILLSMP_BASE_URL=https://skillsmp.com/api
SKILLSMP_API_KEY=
